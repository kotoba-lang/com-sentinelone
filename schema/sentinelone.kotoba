// Sentinelone clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace sentinelone {

    entity Identity {
        id: string @unique
        username: string
        email: string
        status: string
        mfaEnabled: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Policy {
        id: string @unique
        name: string
        effect: string
        resources: string
        actions: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Detection {
        id: string @unique
        severity: string
        rule: string
        entityRef: string
        detectedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Incident {
        id: string @unique
        title: string
        severity: string
        status: string
        assignee: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Asset {
        id: string @unique
        hostname: string
        ipAddress: string
        os: string
        riskScore: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Session {
        id: string @unique
        identityId: string
        source: string
        expiresAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
